#!/bin/bash

clear

echo "LINXMINT SYSTEM"
echo "---------------"
echo "1) Start System"
echo "2) Info"
echo "0) Exit"
echo ""

read -p "> " opt

case "$opt" in
    1)
        linxctl start
        ;;
    2)
        linxctl sys
        ;;
    0)
        exit 0
        ;;
    *)
        echo "ungültig"
        ;;
esac
